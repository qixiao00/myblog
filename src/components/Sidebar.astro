---
import ThemeToggle from "./ThemeToggle.astro";
import SidebarTree from "./SidebarTree.astro";
import { getOpenFolderPaths } from "../lib/notes";
import type { SidebarNode } from "../lib/notes";
import { SITE } from "../lib/site";

interface Props {
  tree: SidebarNode[];
  currentNotePath?: string;
}

const { tree, currentNotePath } = Astro.props;
const openFolders = getOpenFolderPaths(currentNotePath);
---

<div class="surface-panel flex h-full flex-col gap-6 rounded-[2rem] p-5">
  <div class="flex items-start justify-between gap-4">
    <div>
      <p class="text-xs uppercase tracking-[0.32em] text-[var(--muted)]">目录</p>
      <a href="/" class="mt-2 block text-2xl font-semibold tracking-tight text-[var(--foreground)]">
        {SITE.title}
      </a>
      <p class="mt-3 text-sm leading-6 text-[var(--muted)]">{SITE.description}</p>
    </div>
    <button
      type="button"
      data-sidebar-close
      class="inline-flex h-10 w-10 items-center justify-center rounded-full border border-[var(--border)] text-sm text-[var(--muted)] transition hover:border-[var(--accent)] hover:text-[var(--foreground)] lg:hidden"
      aria-label="关闭目录"
    >
      ×
    </button>
  </div>

  <ThemeToggle />

  <nav class="min-h-0 flex-1 overflow-y-auto pr-1">
    {
      tree.length ? (
        <SidebarTree nodes={tree} currentNotePath={currentNotePath} openFolders={openFolders} />
      ) : (
        <p class="rounded-2xl border border-dashed border-[var(--border)] px-4 py-5 text-sm text-[var(--muted)]">
          在 <code class="rounded bg-[var(--bg)] px-1.5 py-0.5 text-xs">vault/</code>
          新建第一篇笔记后，这里会自动生成目录树。
        </p>
      )
    }
  </nav>
</div>
