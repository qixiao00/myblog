---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import { buildSidebarTree } from "../lib/notes";

const notes = await getCollection(
  "notes",
  ({ data }) => !import.meta.env.PROD || !data.draft,
);
const tree = buildSidebarTree(notes);
---

<BaseLayout title="留言板" description="给站长留个言。" tree={tree}>
  <section>
    <h1 class="mt-3 text-4xl font-semibold tracking-tight text-[var(--foreground)]">留言板</h1>
    <p class="mt-4 text-sm text-[var(--muted)]">欢迎留下你的想法、建议或者打个招呼。</p>
  </section>

  <section class="mt-8 border-t border-[var(--border)] pt-8">
    <h2 class="text-2xl font-semibold text-[var(--foreground)]">最新留言</h2>
    <div id="guestbook-list" class="mt-6 space-y-3"></div>
    <p id="guestbook-empty" class="mt-5 text-sm text-[var(--muted)]">还没有留言，来留下第一条吧。</p>
  </section>

  <section class="mt-8 border-t border-[var(--border)] pt-8">
    <h2 class="text-2xl font-semibold text-[var(--foreground)]">新增留言</h2>
    <form method="post" action="/api/comments" data-email-gate class="surface-panel mt-6 space-y-4 rounded-[1.5rem] p-5">
      <input type="hidden" name="slug" value="__guestbook__" />
      <input type="hidden" name="redirectTo" value="/guestbook" />

      <label class="block">
        <span class="mb-2 block text-sm text-[var(--muted)]">邮箱（用于获取头像）</span>
        <input
          name="email"
          type="email"
          required
          maxlength="180"
          data-email-input
          class="w-full rounded-xl border border-[var(--border)] bg-transparent px-3 py-2 text-sm text-[var(--foreground)] outline-none ring-0 transition focus:border-[var(--accent)]"
          placeholder="name@example.com"
        />
      </label>
      <div class="flex items-center gap-3 rounded-xl border border-[var(--border)] px-3 py-2">
        <img
          src="https://api.dicebear.com/9.x/identicon/svg?seed=preview"
          data-email-preview
          data-default="https://api.dicebear.com/9.x/identicon/svg?seed=preview"
          alt="avatar preview"
          class="h-10 w-10 rounded-full border border-[var(--border)] object-cover"
        />
        <p class="text-xs text-[var(--muted)]">输入邮箱后会自动预览头像。</p>
      </div>

      <label class="block">
        <span class="mb-2 block text-sm text-[var(--muted)]">昵称</span>
        <input
          name="nickname"
          required
          maxlength="30"
          data-email-dependent
          disabled
          class="w-full rounded-xl border border-[var(--border)] bg-transparent px-3 py-2 text-sm text-[var(--foreground)] outline-none ring-0 transition focus:border-[var(--accent)] disabled:cursor-not-allowed disabled:opacity-50"
          placeholder="怎么称呼你"
        />
      </label>

      <label class="block">
        <span class="mb-2 block text-sm text-[var(--muted)]">留言内容</span>
        <textarea
          name="content"
          required
          maxlength="1000"
          rows="5"
          data-email-dependent
          disabled
          class="w-full rounded-xl border border-[var(--border)] bg-transparent px-3 py-2 text-sm text-[var(--foreground)] outline-none ring-0 transition focus:border-[var(--accent)] disabled:cursor-not-allowed disabled:opacity-50"
          placeholder="写点什么..."
        ></textarea>
      </label>

      <button
        type="submit"
        data-email-dependent
        disabled
        class="inline-flex items-center rounded-full bg-[var(--accent)] px-4 py-2 text-sm font-medium text-white transition hover:opacity-90 disabled:cursor-not-allowed disabled:opacity-50"
      >
        提交留言
      </button>
    </form>
  </section>

  <script is:inline>
    const listNode = document.querySelector("#guestbook-list");
    const emptyNode = document.querySelector("#guestbook-empty");
    const slug = "__guestbook__";

    const setupEmailGate = (form) => {
      const emailInput = form.querySelector("[data-email-input]");
      const dependentFields = form.querySelectorAll("[data-email-dependent]");
      const preview = form.querySelector("[data-email-preview]");
      if (!emailInput || !dependentFields.length) return;
      let pendingAvatarTimer = null;
      let latestPreviewToken = 0;

      const setPreviewSource = (src, fallback = "") => {
        if (!preview) return;
        preview.onerror = () => {
          if (preview.dataset.fallback) {
            preview.onerror = null;
            preview.src = preview.dataset.fallback;
          }
        };
        preview.src = src || preview.dataset.default || "";
        if (fallback) {
          preview.dataset.fallback = fallback;
        } else {
          delete preview.dataset.fallback;
        }
      };

      const updatePreview = () => {
        if (!preview) return;
        if (!emailInput.checkValidity()) {
          setPreviewSource(preview.dataset.default || "");
          return;
        }

        const token = ++latestPreviewToken;
        fetch(`/api/avatar?email=${encodeURIComponent(emailInput.value.trim())}`)
          .then((res) => (res.ok ? res.json() : null))
          .then((data) => {
            if (token !== latestPreviewToken) return;
            if (!data?.ok) {
              setPreviewSource(preview.dataset.default || "");
              return;
            }
            setPreviewSource(data.avatarUrl || data.avatarFallbackUrl, data.avatarFallbackUrl || "");
          })
          .catch(() => {
            setPreviewSource(preview.dataset.default || "");
          });
      };

      const toggle = () => {
        const enabled = emailInput.value.trim().length > 0 && emailInput.checkValidity();
        dependentFields.forEach((field) => {
          field.disabled = !enabled;
        });
      };

      emailInput.addEventListener("input", toggle);
      emailInput.addEventListener("input", () => {
        if (pendingAvatarTimer) clearTimeout(pendingAvatarTimer);
        pendingAvatarTimer = setTimeout(updatePreview, 220);
      });
      emailInput.addEventListener("blur", toggle);
      emailInput.addEventListener("blur", updatePreview);
      toggle();
      updatePreview();
    };

    document.querySelectorAll("form[data-email-gate]").forEach((form) => setupEmailGate(form));

    const escapeHtml = (input) =>
      String(input ?? "")
        .replace(/&/g, "&amp;")
        .replace(/</g, "&lt;")
        .replace(/>/g, "&gt;")
        .replace(/"/g, "&quot;")
        .replace(/'/g, "&#39;");

    const renderList = (items) => {
      if (!listNode || !emptyNode) return;

      if (!items?.length) {
        emptyNode.classList.remove("hidden");
        listNode.innerHTML = "";
        return;
      }

      emptyNode.classList.add("hidden");
      listNode.innerHTML = items
        .map((comment) => {
          const createdAt = new Date(comment.createdAt);
          const time = Number.isNaN(createdAt.getTime())
            ? ""
            : new Intl.DateTimeFormat("zh-CN", {
                dateStyle: "medium",
                timeStyle: "short",
              }).format(createdAt);

          const avatar = comment.avatarUrl || comment.avatarFallbackUrl || "";
          const fallback = comment.avatarFallbackUrl || "";

          return `
            <article class="surface-panel rounded-[1.25rem] p-4">
              <div class="flex items-start justify-between gap-3">
                <div class="flex min-w-0 items-center gap-3">
                  <img
                    src="${escapeHtml(avatar)}"
                    data-fallback="${escapeHtml(fallback)}"
                    alt="avatar"
                    class="h-10 w-10 rounded-full border border-[var(--border)] object-cover"
                    onerror="if (this.dataset.fallback) { this.onerror=null; this.src=this.dataset.fallback; }"
                  />
                  <p class="truncate font-medium text-[var(--foreground)]">${escapeHtml(comment.nickname)}</p>
                </div>
                <time class="shrink-0 text-xs text-[var(--muted)]">${time}</time>
              </div>
              <p class="mt-2 whitespace-pre-wrap text-sm leading-7 text-[var(--muted)]">${escapeHtml(comment.content)}</p>
            </article>
          `;
        })
        .join("");
    };

    fetch(`/api/comments?slug=${encodeURIComponent(slug)}`)
      .then((res) => (res.ok ? res.json() : null))
      .then((data) => renderList(data?.comments ?? []))
      .catch(() => {});
  </script>
</BaseLayout>
