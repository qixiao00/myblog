---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import {
  buildSidebarTree,
  formatLongDate,
  getNoteFolderLabel,
  getNoteTitle,
  getRecentNotes,
  noteUrlFromId,
} from "../lib/notes";
import { SITE } from "../lib/site";

const notes = await getCollection(
  "notes",
  ({ data }) => !import.meta.env.PROD || !data.draft,
);
const tree = buildSidebarTree(notes);
const recentNotes = getRecentNotes(notes, 6);
---

<BaseLayout title={SITE.title} description={SITE.description} tree={tree}>
  <section
    class="rounded-[1.75rem] border border-[var(--border)] bg-[var(--soft)]/55 p-6 sm:p-8"
  >
    <h1
      class="hero-title font-intro mt-1 max-w-3xl text-4xl leading-tight tracking-tight text-[var(--foreground)] sm:text-5xl"
    >
      你好啊，我是亓qí，我打算在这里写写关于我的东西。
    </h1>
    <div
      class="mt-6 max-w-3xl space-y-5 text-base leading-8 text-[var(--muted)]"
    >
      <p>
        我的朋友们总给我带来难以言说的感觉，以至于需要把我对他们的感受和回忆写下来才行，所以就有了「友人帐」。
      </p>
      <p>「心情」部分是当我有一些情绪时想写的话，其实是情绪化时的产物。</p>
      <p>
        「图文」我想放一些图片上来，我想尽可能地把每一个章节做成一个摄影集一样的东西。
      </p>
      <p>如果你想联系到我请通过邮箱 ikkm541@gmail.com</p>
      <p>祝你开心！</p>
    </div>
    <div class="mt-7 flex flex-wrap gap-3">
      <a
        href="/notes"
        class="inline-flex items-center rounded-full bg-[var(--accent)] px-5 py-3 text-sm font-medium text-white transition hover:opacity-90"
      >
        浏览全部笔记
      </a>
    </div>
  </section>

  <section
    class="mt-8 rounded-[1.75rem] border border-[var(--border)] bg-[var(--bg)]/50 p-6 sm:p-8"
  >
    <div class="flex flex-wrap items-center justify-between gap-3">
      <div>
        <p class="text-xs uppercase tracking-[0.34em] text-[var(--muted)]">
          最近笔记
        </p>
        <h2
          class="mt-2 text-2xl font-semibold tracking-tight text-[var(--foreground)]"
        >
          最近更新
        </h2>
      </div>
      <a
        href="/notes"
        class="text-sm text-[var(--accent)] transition hover:opacity-80"
        >查看全部 -></a
      >
    </div>

    {
      recentNotes.length ? (
        <div class="mt-6 divide-y divide-[var(--border)]/80">
          {recentNotes.map((note) => (
            <a
              href={noteUrlFromId(note.id)}
              class="grid gap-3 py-4 transition hover:translate-x-1 md:grid-cols-[1fr_auto] md:items-center"
            >
              <div>
                <div class="flex flex-wrap items-center gap-x-3 gap-y-1">
                  <h3 class="text-lg font-semibold text-[var(--foreground)]">
                    {getNoteTitle(note)}
                  </h3>
                  <span class="text-xs text-[var(--muted)]">
                    来自 {getNoteFolderLabel(note.id)}
                  </span>
                </div>
                {note.data.description && (
                  <p class="mt-2 max-w-2xl text-sm leading-7 text-[var(--muted)]">
                    {note.data.description}
                  </p>
                )}
              </div>
              <time class="text-sm text-[var(--muted)]">
                {formatLongDate(note.data.date)}
              </time>
            </a>
          ))}
        </div>
      ) : (
        <p class="mt-6 text-sm text-[var(--muted)]">还没有公开笔记。</p>
      )
    }
  </section>
</BaseLayout>
