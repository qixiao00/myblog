---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import {
  buildSidebarTree,
  formatLongDate,
  getNoteFolderLabel,
  getNoteTitle,
  getRecentNotes,
  noteUrlFromId,
} from "../lib/notes";
import { SITE } from "../lib/site";

const notes = await getCollection(
  "notes",
  ({ data }) => !import.meta.env.PROD || !data.draft,
);
const tree = buildSidebarTree(notes);
const recentNotes = getRecentNotes(notes, 6);
const twikooEnvId = import.meta.env.PUBLIC_TWIKOO_ENV_ID ?? "";
const twikooRegion = import.meta.env.PUBLIC_TWIKOO_REGION ?? "";
const twikooJsUrl =
  import.meta.env.PUBLIC_TWIKOO_JS_URL ??
  "https://cdn.jsdelivr.net/npm/twikoo@1.7.7/dist/twikoo.all.min.js";
---

<BaseLayout title={SITE.title} description={SITE.description} tree={tree}>
  <section class="rounded-[1.75rem] border border-[var(--border)] bg-[var(--soft)]/55 p-6 sm:p-8">
    <h1 class="hero-title font-intro mt-1 max-w-6xl text-4xl leading-tight tracking-tight text-[var(--foreground)] sm:text-5xl">
      你好啊，我是亓qí。
    </h1>
    <h1 class="hero-title font-intro mt-2 max-w-6xl text-4xl leading-tight tracking-tight text-[var(--foreground)] sm:text-5xl">
      我打算在这里写写关于我的东西。
    </h1>

    <div class="mt-6 max-w-6xl space-y-5 text-base leading-8 text-[var(--muted)]">
      <p>我的朋友们总给我带来难以言说的感觉，以至于需要把我对他们的感受和回忆写下来才行，所以就有了「友人帐」。</p>
      <p>「心情」部分是当我有一些情绪时想写的话，其实是情绪化时的产物。</p>
      <p>「图文」我想放一些图片上来，我想尽可能地把每一个章节做成一个摄影集一样的东西。</p>
      <p>如果你想联系到我请通过邮箱 ikkm541@gmail.com</p>
      <p>祝你开心！</p>
    </div>

    <div class="mt-7 flex flex-wrap gap-3">
      <a
        href="/notes"
        class="inline-flex items-center rounded-full bg-[var(--accent)] px-5 py-3 text-sm font-medium text-white transition hover:opacity-90"
      >
        浏览全部笔记
      </a>
    </div>
  </section>

  <section class="mt-8 lg:hidden">
    <div class="surface-panel rounded-[1.5rem] p-5">
      <div class="flex items-center justify-between gap-3">
        <h2 class="text-2xl font-semibold tracking-tight text-[var(--foreground)]">最新留言</h2>
        <a
          href="/guestbook"
          class="inline-flex items-center rounded-full border border-[var(--border)]/80 px-3 py-1.5 text-xs text-[var(--accent)] transition hover:border-[var(--accent)]/50 hover:bg-[var(--soft)]"
        >
          去留言板 ->
        </a>
      </div>
      <div data-guestbook-target class="mt-4 space-y-3"></div>
      <p data-guestbook-empty class="mt-5 text-sm text-[var(--muted)]">正在加载留言...</p>
    </div>
  </section>

  <section class="mt-8 rounded-[1.75rem] border border-[var(--border)]/70 bg-[var(--bg)]/35 p-6 sm:p-8">
    <div class="flex flex-wrap items-center justify-between gap-3">
      <div>
        <h2 class="mt-1 text-4xl font-semibold tracking-tight text-[var(--foreground)]">最近更新</h2>
      </div>
      <a
        href="/notes"
        class="inline-flex items-center rounded-full border border-[var(--border)]/80 px-4 py-2 text-sm text-[var(--accent)] transition hover:border-[var(--accent)]/50 hover:bg-[var(--soft)]"
      >
        查看全部 ->
      </a>
    </div>

    {
      recentNotes.length ? (
        <div class="mt-7 divide-y divide-[var(--border)]/60">
          {recentNotes.map((note) => (
            <a
              href={noteUrlFromId(note.id)}
              class="group grid gap-3 py-5 transition md:grid-cols-[1fr_auto] md:items-start"
            >
              <div>
                <h3 class="text-2xl font-semibold leading-[1.35] tracking-normal text-[var(--foreground)] transition group-hover:text-[var(--accent)] [font-family:'Source_Han_Serif_SC','Noto_Serif_SC','Songti_SC','STSong','SimSun',serif]">
                  {getNoteTitle(note)}
                </h3>
                <span class="mt-2 inline-flex rounded-full border border-[var(--border)]/70 px-2.5 py-0.5 text-xs leading-none text-[var(--muted)]">
                  来自 {getNoteFolderLabel(note.id)}
                </span>
                {note.data.description && (
                  <p class="mt-2 max-w-2xl text-sm leading-7 text-[var(--muted)]">
                    {note.data.description}
                  </p>
                )}
              </div>
              <time class="pt-1 text-base leading-[1.35] text-[var(--muted)]/85 md:text-right">
                {formatLongDate(note.data.date)}
              </time>
            </a>
          ))}
        </div>
      ) : (
        <p class="mt-6 text-sm text-[var(--muted)]">还没有公开笔记。</p>
      )
    }
  </section>

  <aside slot="right" class="surface-panel sticky top-24 rounded-[1.5rem] p-5">
    <div class="flex items-center justify-between gap-3">
      <h2 class="text-xl font-semibold tracking-tight text-[var(--foreground)]">最新留言</h2>
      <a
        href="/guestbook"
        class="inline-flex items-center rounded-full border border-[var(--border)]/80 px-3 py-1.5 text-xs text-[var(--accent)] transition hover:border-[var(--accent)]/50 hover:bg-[var(--soft)]"
      >
        去留言板 ->
      </a>
    </div>
    <div data-guestbook-target class="mt-4 space-y-3"></div>
    <p data-guestbook-empty class="mt-5 text-sm text-[var(--muted)]">正在加载留言...</p>
  </aside>

  <script is:inline define:vars={{ twikooEnvId, twikooRegion, twikooJsUrl }}>
    (() => {
      const targetNodes = Array.from(document.querySelectorAll("[data-guestbook-target]"));
      const emptyNodes = Array.from(document.querySelectorAll("[data-guestbook-empty]"));
      if (!targetNodes.length || !emptyNodes.length) {
        return;
      }

      const setEmpty = (message) => {
        emptyNodes.forEach((node) => {
          node.textContent = message;
          node.classList.remove("hidden");
        });
      };

      const setCards = (html) => {
        targetNodes.forEach((node) => {
          node.innerHTML = html;
        });
      };

      if (!twikooEnvId) {
        setEmpty("留言功能未启用。");
        return;
      }

      const loadTwikoo = async () => {
        if (window.twikoo?.getRecentComments) {
          return window.twikoo;
        }

        if (window.__twikooLoaderPromise) {
          return window.__twikooLoaderPromise;
        }

        window.__twikooLoaderPromise = new Promise((resolve, reject) => {
          const existing = document.querySelector('script[data-twikoo-loader="true"]');

          if (existing) {
            existing.addEventListener("load", () => resolve(window.twikoo), { once: true });
            existing.addEventListener(
              "error",
              () => reject(new Error("Twikoo script failed to load.")),
              { once: true },
            );
            return;
          }

          const script = document.createElement("script");
          script.src = twikooJsUrl;
          script.defer = true;
          script.dataset.twikooLoader = "true";
          script.addEventListener("load", () => resolve(window.twikoo), { once: true });
          script.addEventListener(
            "error",
            () => reject(new Error("Twikoo script failed to load.")),
            { once: true },
          );
          document.head.append(script);
        });

        return window.__twikooLoaderPromise;
      };

      const escapeHtml = (value) =>
        String(value ?? "")
          .replace(/&/g, "&amp;")
          .replace(/</g, "&lt;")
          .replace(/>/g, "&gt;")
          .replace(/\"/g, "&quot;")
          .replace(/'/g, "&#39;");

      const formatTime = (value) => {
        const date = new Date(value);
        if (Number.isNaN(date.getTime())) {
          return "时间未知";
        }

        return new Intl.DateTimeFormat("zh-CN", {
          month: "numeric",
          day: "numeric",
          hour: "2-digit",
          minute: "2-digit",
        }).format(date);
      };

      const render = (comments) => {
        if (!Array.isArray(comments) || comments.length === 0) {
          setCards("");
          setEmpty("还没有留言，欢迎来写第一条。");
          return;
        }

        const cards = comments.map((item) => {
          const nick = escapeHtml(item.nick || "匿名访客");
          const text = escapeHtml(item.commentText || "").replace(/\r?\n/g, "<br />");
          const time = escapeHtml(item.relativeTime || formatTime(item.created));
          return `
            <article class="rounded-xl border border-[var(--border)]/80 bg-[var(--panel)] px-3 py-3">
              <div class="flex items-center justify-between gap-3">
                <p class="font-medium text-[var(--foreground)]">${nick}</p>
                <time class="text-xs text-[var(--muted)]">${time}</time>
              </div>
              <p class="mt-2 line-clamp-3 whitespace-pre-wrap text-sm leading-7 text-[var(--muted)]">${text || "（空留言）"}</p>
            </article>
          `;
        }).join("");

        setCards(cards);
        emptyNodes.forEach((node) => node.classList.add("hidden"));
      };

      const init = async () => {
        setEmpty("正在加载留言...");
        try {
          const twikoo = await loadTwikoo();
          const comments = await twikoo.getRecentComments({
            envId: twikooEnvId,
            ...(twikooRegion ? { region: twikooRegion } : {}),
            urls: ["/guestbook"],
            pageSize: 6,
            includeReply: false,
          });

          render(Array.isArray(comments) ? comments.slice(0, 6) : []);
        } catch (error) {
          console.error("[Twikoo] Failed to load homepage recent guestbook comments.", error);
          setEmpty("留言加载失败，请稍后再试。");
        }
      };

      if (document.readyState === "loading") {
        document.addEventListener("DOMContentLoaded", init, { once: true });
      } else {
        init();
      }

      document.addEventListener("astro:page-load", init);
    })();
  </script>
</BaseLayout>
