---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import {
  buildSidebarTree,
  formatLongDate,
  getNoteTitle,
  getRecentNotes,
  noteUrlFromId,
} from "../lib/notes";
import { SITE } from "../lib/site";

const notes = await getCollection(
  "notes",
  ({ data }) => !import.meta.env.PROD || !data.draft,
);
const tree = buildSidebarTree(notes);
const recentNotes = getRecentNotes(notes, 6);
---

<BaseLayout title={SITE.title} description={SITE.description} tree={tree}>
  <section class="rounded-[1.75rem] border border-[var(--border)] bg-[var(--soft)]/55 p-6 sm:p-8">
    <p class="text-xs uppercase tracking-[0.34em] text-[var(--muted)]">个人主页</p>
    <h1 class="mt-4 max-w-3xl text-4xl font-semibold leading-tight tracking-tight text-[var(--foreground)] sm:text-5xl">
      一些笔记、想法和日常记录。
    </h1>
    <p class="mt-5 max-w-2xl text-base leading-8 text-[var(--muted)]">欢迎随便逛逛。</p>
    <div class="mt-7 flex flex-wrap gap-3">
      <a
        href="/notes"
        class="inline-flex items-center rounded-full bg-[var(--accent)] px-5 py-3 text-sm font-medium text-white transition hover:opacity-90"
      >
        浏览全部笔记
      </a>
    </div>
  </section>

  <section class="mt-8 rounded-[1.75rem] border border-[var(--border)] bg-[var(--bg)]/50 p-6 sm:p-8">
    <div class="flex flex-wrap items-center justify-between gap-3">
      <div>
        <p class="text-xs uppercase tracking-[0.34em] text-[var(--muted)]">最近笔记</p>
        <h2 class="mt-2 text-2xl font-semibold tracking-tight text-[var(--foreground)]">最近发布</h2>
      </div>
      <a href="/notes" class="text-sm text-[var(--accent)] transition hover:opacity-80">查看全部 →</a>
    </div>

    {
      recentNotes.length ? (
        <div class="mt-6 divide-y divide-[var(--border)]/80">
          {recentNotes.map((note) => (
            <a
              href={noteUrlFromId(note.id)}
              class="grid gap-2 py-4 transition hover:translate-x-1 md:grid-cols-[1fr_auto] md:items-center"
            >
              <div>
                <h3 class="text-lg font-semibold text-[var(--foreground)]">{getNoteTitle(note)}</h3>
                {note.data.description && (
                  <p class="mt-2 max-w-2xl text-sm leading-7 text-[var(--muted)]">{note.data.description}</p>
                )}
              </div>
              <time class="text-sm text-[var(--muted)]">{formatLongDate(note.data.date)}</time>
            </a>
          ))}
        </div>
      ) : (
        <p class="mt-6 text-sm text-[var(--muted)]">还没有公开笔记。</p>
      )
    }
  </section>
</BaseLayout>
