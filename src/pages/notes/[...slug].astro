---
import { getCollection, render } from "astro:content";
import TwikooComments from "../../components/TwikooComments.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import {
  buildSidebarTree,
  formatLongDate,
  getNoteTitle,
  getSiblingNotes,
  normalizeNoteId,
  noteUrlFromId,
} from "../../lib/notes";
import type { NoteEntry } from "../../lib/notes";

export const prerender = true;

export async function getStaticPaths() {
  const notes = await getCollection(
    "notes",
    ({ data }) => !import.meta.env.PROD || !data.draft,
  );

  return notes.map((entry) => ({
    params: { slug: normalizeNoteId(entry.id) },
    props: { entry },
  }));
}

const { entry } = Astro.props as { entry: NoteEntry };
const notes = await getCollection(
  "notes",
  ({ data }) => !import.meta.env.PROD || !data.draft,
);
const tree = buildSidebarTree(notes);
const currentNotePath = normalizeNoteId(entry.id);
const pageTitle = getNoteTitle(entry);
const noteUrl = noteUrlFromId(entry.id);
const { Content, remarkPluginFrontmatter } = await render(entry);
const readingTime = Number(remarkPluginFrontmatter?.readingTime ?? 1);
const folderLabel = currentNotePath.includes("/") ? currentNotePath.split("/").slice(0, -1).join(" / ") : "顶层";
const tags = entry.data.tags ?? [];
const { previous, next } = getSiblingNotes(notes, entry.id);
---

<BaseLayout
  title={pageTitle}
  description={entry.data.description ?? `${pageTitle} | 笔记`}
  tree={tree}
  currentNotePath={currentNotePath}
>
  <article data-note-slug={currentNotePath}>
    <header class="border-b border-[var(--border)] pb-7">
      <p class="text-xs uppercase tracking-[0.34em] text-[var(--muted)]">{folderLabel}</p>
      <h1 class="mt-4 text-4xl font-semibold leading-tight tracking-tight text-[var(--foreground)] sm:text-5xl">
        {pageTitle}
      </h1>
      {entry.data.description && (
        <p class="mt-5 max-w-3xl text-base leading-8 text-[var(--muted)]">{entry.data.description}</p>
      )}
      <div class="mt-6 flex flex-wrap gap-3 text-sm text-[var(--muted)]">
        <span class="pill">发布于 {formatLongDate(entry.data.date)}</span>
        {entry.data.updated && <span class="pill">更新于 {formatLongDate(entry.data.updated)}</span>}
        <span class="pill">约 {readingTime} 分钟阅读</span>
        <span class="pill">浏览 <span data-view-count>--</span></span>
      </div>
      {
        tags.length > 0 && (
          <div class="mt-4 flex flex-wrap gap-2">
            {tags.map((tag) => (
              <span class="rounded-full border border-[var(--border)] px-3 py-1 text-xs text-[var(--muted)]">#{tag}</span>
            ))}
          </div>
        )
      }
    </header>

    <div class="mt-8">
      <article class="note-prose prose max-w-none prose-headings:font-semibold prose-img:rounded-[1.25rem] prose-img:border prose-img:border-[var(--border)] prose-pre:rounded-[1.25rem] prose-pre:border prose-pre:border-[var(--border)] prose-code:before:content-none prose-code:after:content-none dark:prose-invert">
        <Content />
      </article>
    </div>

    {
      (previous || next) && (
        <nav class="mt-10 grid gap-4 border-t border-[var(--border)] pt-8 md:grid-cols-2">
          {previous ? (
            <a
              href={noteUrlFromId(previous.id)}
              class="surface-panel block rounded-[1.5rem] p-5 transition hover:-translate-y-0.5"
            >
              <p class="text-xs uppercase tracking-[0.24em] text-[var(--muted)]">上一篇</p>
              <h2 class="mt-3 text-lg font-semibold text-[var(--foreground)]">{getNoteTitle(previous)}</h2>
              <p class="mt-2 text-sm text-[var(--muted)]">{formatLongDate(previous.data.date)}</p>
            </a>
          ) : (
            <div class="hidden md:block"></div>
          )}

          {next ? (
            <a
              href={noteUrlFromId(next.id)}
              class="surface-panel block rounded-[1.5rem] p-5 text-left transition hover:-translate-y-0.5 md:text-right"
            >
              <p class="text-xs uppercase tracking-[0.24em] text-[var(--muted)]">下一篇</p>
              <h2 class="mt-3 text-lg font-semibold text-[var(--foreground)]">{getNoteTitle(next)}</h2>
              <p class="mt-2 text-sm text-[var(--muted)]">{formatLongDate(next.data.date)}</p>
            </a>
          ) : (
            <div class="hidden md:block"></div>
          )}
        </nav>
      )
    }

    <TwikooComments path={noteUrl} title="评论" />
  </article>

  <script is:inline>
    const slug = document.querySelector("[data-note-slug]")?.getAttribute("data-note-slug") ?? "";

    if (slug) {
      const body = JSON.stringify({ slug });
      const viewsNode = document.querySelector("[data-view-count]");

      fetch("/api/view", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body,
        keepalive: true,
      })
        .then((res) => (res.ok ? res.json() : null))
        .then((data) => {
          if (!viewsNode || !data?.views) return;
          viewsNode.textContent = Number(data.views).toLocaleString("zh-CN");
        })
        .catch(() => {});
    }
  </script>
</BaseLayout>
